# ==========================================
# API Keys & Credentials Configuration
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ==========================================
# 1. Google Gemini AI API
# ==========================================
# Sign up: https://ai.google.dev/
# Get API Key: https://console.cloud.google.com/
GEMINI_API_KEY=AIzaSyCzO-r-vwR5oIenWtMA7T8SGYP_r-qtil0
GEMINI_MODEL=gemini-2.0-flash-lite

# ==========================================
# 2. SERPAPI - Google Trends
# ==========================================
# Sign up: https://serpapi.com/
# Get API Key: https://serpapi.com/dashboard
SERPAPI_KEY=d32f331a6a671a6d5d73a61e61618d355a495c0f026a663f5f75ce6d99fb6c15

# ==========================================
# 3. YouTube Data API v3
# ==========================================
# Enable in Google Cloud Console: https://console.cloud.google.com/
# Get API Key: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=AIzaSyCBA5uE_Z5rIrpa6uEsFVFQQxlWzgQ0fwE

# ==========================================
# 4. Google Cloud Natural Language API
# ==========================================
# Enable in Google Cloud Console: https://console.cloud.google.com/
# Create Service Account: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download JSON key file and set path below
GOOGLE_CLOUD_CREDENTIALS_PATH=./config/google-cloud-credentials.json
# OR base64 encoded credentials
GOOGLE_CLOUD_CREDENTIALS_JSON=your_base64_encoded_credentials_here

# ==========================================
# 5. Firebase Realtime Database
# ==========================================
# Console: https://console.firebase.google.com/
FIREBASE_DATABASE_URL=https://connect-f885d-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_AUTH_TOKEN=your_firebase_auth_token_here

# ==========================================
# 6. Node-RED Server Configuration
# ==========================================
NODE_RED_PORT=1880
NODE_RED_USER=admin
NODE_RED_PASSWORD=change_me_in_production

# ==========================================
# 7. Application Configuration
# ==========================================
NODE_ENV=development
DEBUG=false
